# ─── Sanity (public + server) ─────────────────────────────────────────────
# Must match Studio / Vercel — code falls back to qxv0mc90 + production if unset
NEXT_PUBLIC_SANITY_PROJECT_ID=qxv0mc90
NEXT_PUBLIC_SANITY_DATASET=production
# Base URL of the marketing site (used by Presentation tool + stega overlays)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Read token with Viewer permissions — required for Presentation / draft-mode URL validation
SANITY_API_READ_TOKEN=

# Write token — required for /api/inquiry to create Inquiry Submissions in Sanity
SANITY_API_WRITE_TOKEN=

# Secret for Sanity webhook → POST /api/revalidate?secret=...
# In Sanity: Project → API → Webhooks → URL like https://YOUR_DOMAIN/api/revalidate?secret=THIS_VALUE
SANITY_REVALIDATE_SECRET=

# ─── Resend (transactional email from /api/inquiry) ───────────────────────
RESEND_API_KEY=
RESEND_TO_EMAIL=
# Optional: verified sender in Resend (defaults to onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=
